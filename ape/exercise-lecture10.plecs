      LabelPosition south
      Frame         [-20, -20; 20, 20]
      SampleTime    "-1"
      CodeGenDiscretizationMethod "2"
      CodeGenTarget "Generic"
      MaskType      "Variable Frequency PWM"
      MaskDescription "PWM generator with variable carrier frequency. If the m"
" input is a vector, the output is also a vector of the same width. The f' inp"
"ut is used to scale the nominal carrier frequency. "
      MaskHelp      "qthelp:///components-by-category/varfreqpwm.html"
      MaskDisplayLang "2"
      MaskIconFrame on
      MaskIconOpaque off
      MaskIconRotates on
      MaskInit      "NominalPeriod = 1/Frequency;\n"
"if CarrierType == 2\n"
"\tNominalPeriod = NominalPeriod / 2;\n"
"else\n"
"\tSampling = 1;\n"
"end\n"
"\n"
"Sampling = Sampling - 1;\n"
"CarrierType = CarrierType - 1;"
      MaskDialogCallback "Dialog:set('Sampling', 'Visible', Dialog:get('Carrie"
"rType') ~= '1')  "
      Parameter {
        Variable      "CarrierType"
        Prompt        "Carrier type"
        Type          FixedText
        PossibleValues {"Sawtooth (carrier counts up)", "Symmetrical (carrier "
