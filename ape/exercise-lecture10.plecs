        Component {
          Type          CScript
          Name          "C-Script"
          Show          on
          Position      [420, 65]
          Direction     up
          Flipped       off
          LabelPosition south
          Parameter {
            Variable      "DialogGeometry"
            Value         "[832 53 1087 944]"
            Show          off
          }
          Parameter {
            Variable      "NumInputs"
            Value         "[-1 1]"
            Show          off
          }
          Parameter {
            Variable      "NumOutputs"
            Value         "[-1 -1 -1 -1 -1 1]"
            Show          off
          }
          Parameter {
            Variable      "NumContStates"
            Value         "0"
            Show          off
          }
          Parameter {
            Variable      "NumDiscStates"
            Value         "0"
            Show          off
          }
          Parameter {
            Variable      "NumZCSignals"
            Value         "0"
            Show          off
          }
          Parameter {
            Variable      "DirectFeedthrough"
            Value         "1"
            Show          off
          }
          Parameter {
            Variable      "Ts"
            Value         "[0, 0; -2, 0; 1/Frequency, 0]"
            Show          off
          }
          Parameter {
            Variable      "TerminalBasedSampleTimes"
            Value         "1"
            Show          off
          }
          Parameter {
            Variable      "Parameters"
            Value         "NominalPeriod, Sampling, CarrierType, OutputValues"
            Show          off
          }
          Parameter {
            Variable      "LangStandard"
            Value         "2"
            Show          off
          }
          Parameter {
            Variable      "GnuExtensions"
            Value         "1"
            Show          off
          }
          Parameter {
            Variable      "RuntimeCheck"
            Value         "2"
            Show          off
          }
          Parameter {
            Variable      "HighlightLevel"
            Value         "0"
            Show          off
          }
          Parameter {
            Variable      "Declarations"
            Value         "#include <float.h>\n"
"#include <math.h>\n"
"#include <stdio.h>\n"
"#include <stdint.h>\n"
"#include <stdlib.h>\n"
"\n"
"#define COUNTER_ZERO\t\t\t\t0\n"
"#define COUNTER_PERIOD\t\t\t1\n"
"#define COUNTER_ZERO_PERIOD\t2\n"
"\n"
"#define CARRIER_TYPE_SAWTOOTH 0\n"
"#define CARRIER_TYPE_TRIANGLE 1\n"
"\n"
"#define PAR_NominalPeriod \t\t\tParamRealData(0, 0)\n"
"#define PAR_Sampling\t\t\t\t\tParamRealData(1, 0)\n"
"#define PAR_CarrierType\t\t\t\tParamRealData(2, 0)\n"
"#define OUTPUT_OFF \t\t\t\t\tParamRealData(3, 0)\n"
"#define OUTPUT_ON  \t\t\t\t\tParamRealData(3, 1)\n"
"\n"
"\n"
"#define IN_Durations(i)\t\t\t\tInputSignal(0, (i))\n"
"#define IN_PeriodScaler\t\t\t\tInputSignal(1, 0)\n"
"\n"
"static double DS_COUNTER;\n"
"\n"
"// Custom states\n"
"static double* CS_LatchedDurations = NULL;\n"
"static double* CS_NextPeriodEvent = NULL;\n"
"static double* CS_NextCompareEvent = NULL;\n"
"static double* CS_Carrier = NULL;\n"
"static int*\t\tCS_CountingUp = NULL;\n"
"static int*\t\tCS_OutputBit = NULL;\n"
"static int* \tCS_PeriodHitFlag = NULL;\n"
"static int*\t\tCS_ZeroHitFlag = NULL;\n"
"\n"
"static int \t\tNumChannels;\n"
"static double\tCS_LatchedPeriodScaler;\n"
"\n"
"static int \t\tReloadDutyAtZeroHit;\n"
"static int\t\tReloadDutyAtPeriodHit;\n"
"\n"
"// Macro definitions for bit operations\n"
"#define TOGGLE_BIT(i) (CS_OutputBit[i] ^= (1<<0))\n"
"#define SET_BIT(i) (CS_OutputBit[i] |= (1<<0))\n"
"#define CLEAR_BIT(i) (CS_OutputBit[i] &= ~(1<<0))\n"
            Show          off
          }
          Parameter {
            Variable      "StartFcn"
            Value         "// Number of channels must be equal to the number o"
"f input signals\n"
"NumChannels = NumInputSignals(0);\n"
"\n"
"if (ParamNumDims(0) != 2 || ParamDim(0, 0) != 1 || ParamDim(0, 1) != 1\n"
"    || PAR_NominalPeriod <= 0.0)\n"
"{\n"
"   SetErrorMessage(\"Error in parameter 'Nominal Period': positive number exp"
"ected.\");\n"
"   return;\n"
"}\n"
"\n"
"CS_OutputBit = (int*) malloc(NumChannels*sizeof(int));\n"
"CS_CountingUp = (int*) malloc(NumChannels*sizeof(int));\n"
"CS_NextCompareEvent = (double*) malloc(NumChannels*sizeof(double));\n"
"CS_NextPeriodEvent = (double*) malloc(NumChannels*sizeof(double));\n"
"CS_LatchedDurations = (double*) malloc(NumChannels*sizeof(double));\n"
"CS_PeriodHitFlag = (int*) malloc(NumChannels*sizeof(int));\n"
"CS_ZeroHitFlag = (int*) malloc(NumChannels*sizeof(int));\n"
"CS_Carrier = (double*) malloc(NumChannels*sizeof(double));\n"
"\n"
"if (!CS_ZeroHitFlag || !CS_PeriodHitFlag || !CS_LatchedDurations || !CS_NextP"
"eriodEvent || !CS_NextCompareEvent || !CS_CountingUp || !CS_OutputBit || !CS_"
"Carrier)\n"
"{\n"
"\tSetErrorMessage(\"Cannot allocate memory.\");\n"
"\treturn;\n"
"}\n"
"\n"
"// Initialize allocated memory\n"
"for (int i=0; i < NumChannels;i++)\n"
"{\n"
"\tCS_CountingUp[i] = 0;\n"
"\tCS_OutputBit[i] = 0;\n"
"   CS_NextCompareEvent[i] = DBL_MAX;\n"
"\tCS_NextPeriodEvent[i] = CurrentTime;\n"
"\tCS_PeriodHitFlag[i] = 0;\n"
"\tCS_ZeroHitFlag[i] = 0;\n"
"\tCS_LatchedDurations[i] = 0.0;\n"
"\tCS_Carrier[i] = 0.0;\n"
"}\n"
"\n"
"CS_LatchedPeriodScaler = 1.0;\n"
"DS_COUNTER = CurrentTime/PAR_NominalPeriod;\n"
"\n"
"if ((PAR_Sampling == COUNTER_ZERO || PAR_Sampling == COUNTER_ZERO_PERIOD))\n"
"{\n"
"\tReloadDutyAtZeroHit = 1;\n"
"}\n"
"else\n"
"{\n"
"\tReloadDutyAtZeroHit = 0;\n"
"}\n"
"\n"
"if ((PAR_Sampling == COUNTER_PERIOD || PAR_Sampling == COUNTER_ZERO_PERIOD))"
"\n"
"{\n"
"\tReloadDutyAtPeriodHit = 1;\n"
"}\n"
"else\n"
"{\n"
"\tReloadDutyAtPeriodHit = 0;\n"
"}\n"
"\n"
"NextSampleHit = CurrentTime;"
            Show          off
          }
          Parameter {
            Variable      "OutputFcn"
            Value         "if (IsMajorStep)\n"
"{\n"
"\t// Always reset flags\n"
"\tfor (int i=0; i < NumChannels; i++)\n"
"\t{\n"
"\t   CS_PeriodHitFlag[i] = 0;\n"
"\t   CS_ZeroHitFlag[i] = 0;\n"
"\t}\n"
"\n"
"\t// Discrete-variable sample time\n"
"\tif(IsSampleHit(1))\n"
"\t{\t\n"
"\t\tfor (int i = 0; i < NumChannels; i++)\n"
"\t\t{\n"
"\t\t\tif (fabs(CS_NextPeriodEvent[i] - CurrentTime) <= fabs(CurrentTime * 128"
" * DBL_EPSILON))\n"
"\t\t\t{\n"
"\t\t\t\tif(CS_CountingUp[i] == 1)\n"
"\t\t\t\t{\n"
"\t\t\t\t\tif (PAR_CarrierType == CARRIER_TYPE_TRIANGLE)\n"
"\t\t\t\t\t{\n"
"\t\t\t\t\t\tCS_PeriodHitFlag[i] = 1;\n"
"\t\t\t\t\t}\n"
"\t\t\t\t\telse\n"
"\t\t\t\t\t{\n"
"\t\t\t\t\t\tCS_ZeroHitFlag[i] = 1;\n"
"\t\t\t\t\t}\t\n"
"\t\t\t\t}\n"
"\t\t\t\telse\n"
"\t\t\t\t{\n"
"\t\t\t\t\tCS_ZeroHitFlag[i] = 1;\n"
"\t\t\t\t}\n"
"\t\t\t}\n"
"\t\t\tif (fabs(CS_NextCompareEvent[i] - CurrentTime) <= fabs(CurrentTime * 12"
"8 * DBL_EPSILON))\n"
"\t\t\t{\n"
"\t\t\t\tif (CS_CountingUp[i] == 1)\n"
"\t\t\t\t{\n"
"\t\t\t\t\tCLEAR_BIT(i);\t\t\n"
"\t\t\t\t\tCS_NextCompareEvent[i] = DBL_MAX;\n"
"\t\t\t\t}\n"
"\t\t\t\telse\n"
"\t\t\t\t{\n"
"\t\t\t\t\tSET_BIT(i);\n"
"\t\t\t\t\tCS_NextCompareEvent[i] = DBL_MAX;\n"
"\t\t\t\t}\n"
"\t\t\t}\n"
"\t\t\tif(CS_PeriodHitFlag[i] == 1)\n"
"\t\t\t{\n"
"\t\t\t\tif (ReloadDutyAtPeriodHit)\n"
"\t\t\t\t{\n"
"\t\t\t\t\tCS_LatchedDurations[i] = IN_Durations(i);\n"
"\t\t\t\t\tif ((DS_COUNTER + CS_LatchedDurations[i]) * PAR_NominalPeriod <= (D"
"S_COUNTER) * PAR_NominalPeriod)\n"
"\t\t\t\t\t{\n"
"\t\t\t\t\t\tCS_LatchedDurations[i] = 0.0;\n"
"\t\t\t\t\t}\n"
"\t\t\t\t\telse if ((DS_COUNTER + CS_LatchedDurations[i]) * PAR_NominalPeriod "
">= (DS_COUNTER + 1) * PAR_NominalPeriod)\n"
"\t\t\t\t\t{\n"
"\t\t\t\t\t\tCS_LatchedDurations[i] = 1.0;\n"
"\t\t\t\t\t}\n"
"\t\t\t\t}\n"
"\t\t\t\tif (CS_LatchedDurations[i] > 0.0 && CS_LatchedDurations[i] < 1.0)\n"
"\t\t\t\t{\n"
"\t\t\t\t\tCLEAR_BIT(i);\n"
"\t\t\t\t\tCS_NextCompareEvent[i] = (DS_COUNTER + CS_LatchedPeriodScaler - CS_"
"LatchedDurations[i] * CS_LatchedPeriodScaler) * PAR_NominalPeriod;\n"
"\t\t\t\t}\n"
"\t\t\t\telse\n"
"\t\t\t\t{\n"
"\t\t\t\t\tif (CS_LatchedDurations[i] == 0.0)\n"
"\t\t\t\t\t{\n"
"\t\t\t\t\t\tCLEAR_BIT(i);\n"
"\t\t\t\t\t}\n"
"\t\t\t\t\telse\n"
"\t\t\t\t\t{\n"
"\t\t\t\t\t\tSET_BIT(i);\n"
"\t\t\t\t\t}\n"
"\t\t\t\t\tCS_NextCompareEvent[i] = DBL_MAX;\n"
"\t\t\t\t}\n"
"\t\t\t\tCS_NextPeriodEvent[i] = (DS_COUNTER + CS_LatchedPeriodScaler) * PAR_N"
"ominalPeriod;\n"
"\t\t\t\tCS_CountingUp[i] = 0;\n"
"\t\t\t}\n"
"\t\t\tif(CS_ZeroHitFlag[i] == 1)\n"
"\t\t\t{\n"
"\t\t\t\tif (i == 0)\n"
"\t\t\t\t{\n"
"\t\t\t\t\tCS_LatchedPeriodScaler = IN_PeriodScaler;\n"
"\t\t\t\t\tif (CS_LatchedPeriodScaler <= 0.0 || (CS_LatchedPeriodScaler < DS_C"
"OUNTER * PAR_NominalPeriod * DBL_EPSILON * 128))\n"
"\t  \t\t\t\t{\n"
"\t  \t\t\t\t\tSetErrorMessage(\"Period has to be positve and non-zero!\");\n"
"\t  \t\t\t\t}\n"
"\t\t\t\t}\n"
"\t\t\t\tif (ReloadDutyAtZeroHit)\n"
"\t\t\t\t{\n"
"\t\t\t\t\tCS_LatchedDurations[i] = IN_Durations(i);\n"
"\t\t\t\t\tif ((DS_COUNTER + CS_LatchedDurations[i]) * PAR_NominalPeriod <= (D"
"S_COUNTER) * PAR_NominalPeriod)\n"
"\t\t\t\t\t{\n"
"\t\t\t\t\t\tCS_LatchedDurations[i] = 0.0;\n"
"\t\t\t\t\t}\n"
"\t\t\t\t\telse if ((DS_COUNTER + CS_LatchedDurations[i]) * PAR_NominalPeriod "
">= (DS_COUNTER + 1) * PAR_NominalPeriod)\n"
"\t\t\t\t\t{\n"
"\t\t\t\t\t\tCS_LatchedDurations[i] = 1.0;\n"
"\t\t\t\t\t}\n"
"\t\t\t\t}\n"
"\t\t\t\tif (CS_LatchedDurations[i] > 0.0 && CS_LatchedDurations[i] < 1.0)\n"
"\t\t\t\t{\n"
"\t\t\t\t\tSET_BIT(i);\n"
"\t\t\t\t\tCS_NextCompareEvent[i] = (DS_COUNTER + CS_LatchedDurations[i] * CS_"
"LatchedPeriodScaler) * PAR_NominalPeriod;\n"
"\t\t\t\t}\n"
"\t\t\t\telse\n"
"\t\t\t\t{\n"
"\t\t\t\t\tif (CS_LatchedDurations[i] == 0.0)\n"
"\t\t\t\t\t{\n"
"\t\t\t\t\t\tCLEAR_BIT(i);\n"
"\t\t\t\t\t}\n"
"\t\t\t\t\telse\n"
"\t\t\t\t\t{\n"
"\t\t\t\t\t\tSET_BIT(i);\n"
"\t\t\t\t\t}\n"
"\t\t\t\t\tCS_NextCompareEvent[i] = DBL_MAX;\n"
"\t\t\t\t}\n"
"\t\t\t\tCS_NextPeriodEvent[i] = (DS_COUNTER + CS_LatchedPeriodScaler) * PAR_N"
"ominalPeriod;\n"
"\t\t\t\tCS_CountingUp[i] = 1;\n"
"\t\t\t}\n"
"\t\t}\n"
"\t\tdouble nextHit = DBL_MAX;\n"
"\t\tfor (int i=0; i < NumChannels; i++)\n"
"\t\t{\n"
"\t\t\tif (CS_NextCompareEvent[i] < nextHit)\n"
"\t \t  \t{\n"
"\t\t\t\tnextHit = CS_NextCompareEvent[i];\n"
"\t \t \t}\n"
"\t  \t\tif (CS_NextPeriodEvent[i] <= nextHit)\n"
"\t   \t{\n"
"\t   \t\tnextHit = CS_NextPeriodEvent[i];\n"
"\t   \t}\n"
"\t\t}\n"
"\t\tif (nextHit <= CurrentTime)\n"
"\t\t{\n"
"\t\t\tSetErrorMessage(\"Implementation error: Not moving forward!\");\n"
"\t\t}\n"
"\t\tNextSampleHit = nextHit;\n"
"\t\tif ((CS_ZeroHitFlag[0] == 1 || CS_PeriodHitFlag[0] == 1))\n"
"\t\t{\n"
"\t\t\tDS_COUNTER = DS_COUNTER + CS_LatchedPeriodScaler;\n"
"\t\t}\n"
"\t}\n"
"}\n"
"// interpolate carrier\n"
"for (int i=0; i < NumChannels; i++)\n"
"{\n"
"\tdouble output = 0.0;\n"
"\tif(CS_CountingUp[i] == 1)\n"
"\t{\n"
"\t\toutput = 1 - (CS_NextPeriodEvent[i] - CurrentTime) / (PAR_NominalPeriod *"
" CS_LatchedPeriodScaler);\n"
"\t}\n"
"\telse\n"
"\t{\n"
"\t\toutput = (CS_NextPeriodEvent[i] - CurrentTime) / (PAR_NominalPeriod * CS_"
"LatchedPeriodScaler);\n"
"\t}\n"
"\tCS_Carrier[i] = output;\n"
"}\n"
"\n"
"// Apply values to outputs\n"
"for (int i=0; i < NumChannels; i++)\n"
"{\n"
"\tOutputSignal(0,i) = CS_OutputBit[i] ? OUTPUT_ON : OUTPUT_OFF;\n"
"\tOutputSignal(1,i) = CS_PeriodHitFlag[i];\n"
"\tOutputSignal(2,i) = CS_ZeroHitFlag[i];\n"
"\tOutputSignal(3,i) = CS_CountingUp[i];\n"
"\tOutputSignal(4,i) = CS_Carrier[i];\n"
"}\n"
"// Output first carrier to schedule additional sample hit if duty of 0.0 for "
"all channels and sawtooth carrier\n"
"OutputSignal(5,0) = CS_Carrier[0];\n"
            Show          off
          }
          Parameter {
            Variable      "UpdateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "DerivativeFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "TerminateFcn"
            Value         "free(CS_OutputBit);\n"
"free(CS_CountingUp);\n"
"free(CS_LatchedDurations);\n"
"free(CS_NextPeriodEvent);\n"
"free(CS_NextCompareEvent);\n"
"free(CS_PeriodHitFlag);\n"
"free(CS_ZeroHitFlag);\n"
"free(CS_Carrier);\n"
            Show          off
          }
          Parameter {
            Variable      "StoreCustomStateFcn"
            Value         "for (int i=0; i < NumChannels;i++)\n"
"{\n"
"\tWriteCustomStateInt(CS_CountingUp[i]);\n"
"\tWriteCustomStateInt(CS_OutputBit[i]);\n"
"\tWriteCustomStateInt(CS_PeriodHitFlag[i]);\n"
"\tWriteCustomStateInt(CS_ZeroHitFlag[i]);\n"
"\tWriteCustomStateDouble(CS_LatchedDurations[i]);\n"
"\tWriteCustomStateDouble(CS_NextPeriodEvent[i]);\n"
"\tWriteCustomStateDouble(CS_NextCompareEvent[i]);\n"
"\tWriteCustomStateDouble(CS_Carrier[i]);\n"
"}\n"
"\n"
"WriteCustomStateDouble(CS_LatchedPeriodScaler);\n"
"WriteCustomStateDouble(DS_COUNTER);\n"
            Show          off
          }
          Parameter {
            Variable      "RestoreCustomStateFcn"
            Value         "for (int i=0; i < NumChannels;i++)\n"
"{\n"
"\tCS_CountingUp[i] = ReadCustomStateInt();\n"
"\tCS_OutputBit[i] = ReadCustomStateInt();\n"
"\tCS_PeriodHitFlag[i] = ReadCustomStateInt();\n"
"\tCS_ZeroHitFlag[i] = ReadCustomStateInt();\n"
"\tCS_LatchedDurations[i] = ReadCustomStateDouble();\n"
"\tCS_NextPeriodEvent[i] = ReadCustomStateDouble();\n"
"\tCS_NextCompareEvent[i] = ReadCustomStateDouble();\n"
"\tCS_Carrier[i] = ReadCustomStateDouble();\n"
"}\n"
"\n"
"CS_LatchedPeriodScaler = ReadCustomStateDouble();\n"
"DS_COUNTER = ReadCustomStateDouble();"
            Show          off
          }
        }
        Component {
