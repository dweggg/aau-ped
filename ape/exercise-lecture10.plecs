          }
          TerminalNames { "p", "p'", "z", "z'" }
          Location      [468, 133; 1079, 368]
          ZoomFactor    1
          SliderPosition [0, 0]
          ShowBrowser   off
          BrowserWidth  100
          Configurations {
            Name          "Sawtooth"
            Schematic {
              Component {
                Type          Input
                Name          "p"
                Show          on
                Position      [140, 80]
                Direction     right
                Flipped       off
                LabelPosition south
                Parameter {
                  Variable      "Index"
                  Value         "1"
                  Show          on
                }
                Parameter {
                  Variable      "Width"
                  Value         "-1"
                  Show          off
                }
              }
              Component {
